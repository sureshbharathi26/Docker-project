.env.test.local
.env.production.local
*.env

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs
*.log

# Operating System files
.DS_Store
Thumbs.db
.directory

# IDE / Editor folders
.visualstudio
.vscode/
.idea/
*.swp
*.swo

# Docker specific (Optional: if you don't want to sync local data)
mongo-data/